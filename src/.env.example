APP_NAME=SalmaDrive
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Pesepay payment gateway (set per environment — never commit real keys)
PESEPAY_INTEGRATION_KEY=
PESEPAY_ENCRYPTION_KEY=
PESEPAY_BASE_URL=https://api.pesepay.com/api/payments-engine
PESEPAY_DEFAULT_CURRENCY=USD
PESEPAY_METHOD_ECOCASH=PZW211
PESEPAY_METHOD_INNBUCKS=PZW212

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# Security — set SESSION_SECURE_COOKIE=true in production (HTTPS only).
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax
SESSION_HTTP_ONLY=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=live.smtp.mailtrap.io
MAIL_PORT=587
MAIL_USERNAME=api
MAIL_PASSWORD=your-mailtrap-api-token
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@salmadrive.co.zw"
MAIL_FROM_NAME="SalmaDrive"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# ─── Super Admin (local dev seed) ────────────────────────────────────────────
SUPER_ADMIN_EMAIL=admin@dev.local
SUPER_ADMIN_PASSWORD=SuperAdmin@2025
