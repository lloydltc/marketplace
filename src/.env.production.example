# SalmaDrive — production .env template (P7). Copy to .env on the server and fill
# every <…>. NEVER commit the real .env. See docs/DEPLOYMENT.md §2.

APP_NAME=SalmaDrive
APP_ENV=production
APP_KEY=                      # php artisan key:generate (store with DB backups — decrypts bank data)
APP_DEBUG=false
APP_URL=https://salmadrive.co.zw

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_LEVEL=warning

# Database (managed PG with PITR strongly preferred — see §7)
DB_CONNECTION=pgsql
DB_HOST=<db-host>
DB_PORT=5432
DB_DATABASE=marketplace
DB_USERNAME=<db-user>
DB_PASSWORD=<db-password>

# Redis (cache + sessions + queue)
REDIS_HOST=<redis-host>
REDIS_PASSWORD=<redis-password>
REDIS_PORT=6379

CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

# Security — HTTPS-only cookies + SameSite (P3)
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax
SESSION_HTTP_ONLY=true

# Object storage (DigitalOcean Spaces, S3-compatible) — enable bucket versioning
FILESYSTEM_DISK=s3
AWS_ACCESS_KEY_ID=<spaces-key>
AWS_SECRET_ACCESS_KEY=<spaces-secret>
AWS_DEFAULT_REGION=<region>
AWS_BUCKET=<bucket>
AWS_ENDPOINT=https://<region>.digitaloceanspaces.com
AWS_USE_PATH_STYLE_ENDPOINT=false

# Mail (configure SPF/DKIM/DMARC for the sending domain — P9)
MAIL_MAILER=smtp
MAIL_HOST=<smtp-host>
MAIL_PORT=587
MAIL_USERNAME=<smtp-user>
MAIL_PASSWORD=<smtp-password>
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@salmadrive.co.zw
MAIL_FROM_NAME="SalmaDrive"

# Pesepay — LIVE keys from the dashboard (never commit)
PESEPAY_ENCRYPTION_KEY=<live-encryption-key>
PESEPAY_INTEGRATION_KEY=<live-integration-key>

# Error tracking (after: composer require sentry/sentry-laravel)
SENTRY_LARAVEL_DSN=<sentry-dsn>
SENTRY_TRACES_SAMPLE_RATE=0.1
