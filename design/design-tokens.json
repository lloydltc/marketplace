{
  "$meta": {
    "name": "Salma Drive Design Tokens",
    "version": "1.0.0",
    "themes": ["light", "dark"],
    "systemAware": true,
    "stack": "blade-tailwind-alpine"
  },
  "color": {
    "brand": {
      "50": "#FDF6E7", "100": "#FBEAC2", "200": "#F7D98A", "300": "#F4C95C",
      "400": "#F2B93C", "500": "#F0A820", "600": "#D08D12", "700": "#A66E0E",
      "800": "#7D530C", "900": "#5C3D0A"
    },
    "neutral": {
      "0": "#FFFFFF", "50": "#F6F7F9", "100": "#ECEEF1", "200": "#DCDFE5",
      "300": "#C8CDD6", "400": "#9CA3B0", "500": "#5A6070", "600": "#454B59",
      "700": "#313643", "800": "#1A1A24", "900": "#0F0F16", "950": "#080810"
    },
    "success": { "DEFAULT": "#2EBD7A", "subtle": "#E7F8F0", "strong": "#1E8A58" },
    "info":    { "DEFAULT": "#3DB8E8", "subtle": "#E6F6FD", "strong": "#1F8FBE" },
    "danger":  { "DEFAULT": "#D4295A", "subtle": "#FBE7ED", "strong": "#A81D47" },
    "warning": { "DEFAULT": "#EA7A1C", "subtle": "#FDEFE2", "strong": "#B85B12" }
  },
  "semantic": {
    "light": {
      "bg-base": "#F6F7F9", "bg-surface": "#FFFFFF", "bg-surface-2": "#ECEEF1",
      "bg-sidebar": "#1A1A24", "border": "#DCDFE5", "border-strong": "#C8CDD6",
      "text-strong": "#0F0F16", "text": "#313643", "text-muted": "#5A6070",
      "brand": "#F0A820", "brand-hover": "#D08D12", "text-on-brand": "#0F0F16", "ring": "#F0A820",
      "success": "#2EBD7A", "info": "#1F8FBE", "danger": "#D4295A", "warning": "#EA7A1C"
    },
    "dark": {
      "bg-base": "#080810", "bg-surface": "#1A1A24", "bg-surface-2": "#313643",
      "bg-sidebar": "#080810", "border": "#313643", "border-strong": "#454B59",
      "text-strong": "#F6F7F9", "text": "#DCDFE5", "text-muted": "#9CA3B0",
      "brand": "#F0A820", "brand-hover": "#F2B93C", "text-on-brand": "#0F0F16", "ring": "#F2B93C",
      "success": "#2EBD7A", "info": "#3DB8E8", "danger": "#E8467A", "warning": "#F0902F"
    }
  },
  "typography": {
    "fontFamily": {
      "display": ["Sora", "system-ui", "sans-serif"],
      "body": ["Plus Jakarta Sans", "system-ui", "sans-serif"],
      "mono": ["IBM Plex Mono", "ui-monospace", "monospace"]
    },
    "weight": { "regular": 400, "medium": 500, "semibold": 600, "bold": 700 },
    "scale": {
      "display-2xl": { "size": "3.5rem", "lineHeight": "1.05", "weight": 700, "family": "display" },
      "display-xl":  { "size": "2.75rem", "lineHeight": "1.1", "weight": 700, "family": "display" },
      "display-lg":  { "size": "2.25rem", "lineHeight": "1.1", "weight": 700, "family": "display" },
      "h1": { "size": "1.875rem", "lineHeight": "1.2", "weight": 600, "family": "display" },
      "h2": { "size": "1.5rem", "lineHeight": "1.25", "weight": 600, "family": "display" },
      "h3": { "size": "1.25rem", "lineHeight": "1.3", "weight": 600, "family": "display" },
      "h4": { "size": "1.125rem", "lineHeight": "1.4", "weight": 600, "family": "body" },
      "body-lg": { "size": "1.0625rem", "lineHeight": "1.6", "weight": 400, "family": "body" },
      "body": { "size": "1rem", "lineHeight": "1.6", "weight": 400, "family": "body" },
      "body-sm": { "size": "0.875rem", "lineHeight": "1.55", "weight": 400, "family": "body" },
      "caption": { "size": "0.75rem", "lineHeight": "1.5", "weight": 500, "family": "body" },
      "overline": { "size": "0.6875rem", "lineHeight": "1.4", "weight": 600, "family": "body", "letterSpacing": "0.08em", "transform": "uppercase" },
      "price": { "size": "1.5rem", "lineHeight": "1.1", "weight": 700, "family": "body", "numeric": "tabular-nums" }
    }
  },
  "spacing": {
    "base": "4px",
    "scale": { "0": "0", "1": "4px", "2": "8px", "3": "12px", "4": "16px", "5": "20px", "6": "24px", "8": "32px", "10": "40px", "12": "48px", "16": "64px", "20": "80px" },
    "section": { "y-mobile": "32px", "y-desktop": "64px" },
    "cardPadding": { "sm": "16px", "md": "20px", "lg": "24px" }
  },
  "radius": { "sm": "6px", "md": "10px", "lg": "14px", "xl": "20px", "2xl": "28px", "full": "9999px" },
  "shadow": {
    "light": {
      "e1": "0 1px 2px rgba(8,8,16,.06), 0 1px 3px rgba(8,8,16,.10)",
      "e2": "0 2px 6px rgba(8,8,16,.08), 0 4px 12px rgba(8,8,16,.10)",
      "e3": "0 8px 24px rgba(8,8,16,.12)",
      "e4": "0 16px 48px rgba(8,8,16,.18)"
    },
    "dark": {
      "e1": "0 1px 2px rgba(0,0,0,.4)",
      "e2": "0 4px 12px rgba(0,0,0,.45)",
      "e3": "0 8px 24px rgba(0,0,0,.5)",
      "e4": "0 16px 48px rgba(0,0,0,.6)"
    }
  },
  "motion": {
    "duration": { "micro": "150ms", "default": "200ms", "overlay": "300ms" },
    "easing": "cubic-bezier(.2,0,0,1)",
    "respectReducedMotion": true
  },
  "breakpoints": { "sm": "640px", "md": "768px", "lg": "1024px", "xl": "1280px", "2xl": "1536px", "3xl": "1920px" },
  "container": { "default": "1280px", "wide": "1440px" },
  "zIndex": { "base": 0, "dropdown": 1000, "sticky": 1020, "drawer": 1030, "modal": 1040, "toast": 1050, "tooltip": 1060 }
}
